NODE_ENV=development
PORT=5000

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=edutract_user
DATABASE_PASSWORD=edutract_password_secure
DATABASE_NAME=edutract_db
DATABASE_URL=postgresql://edutract_user:edutract_password_secure@localhost:5432/edutract_db

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRE=7d

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM=noreply@edutracknigeria.com

# File Upload
MAX_FILE_SIZE=52428800
ALLOWED_FILE_TYPES=.pdf,.jpg,.jpeg,.png,.doc,.docx,.xls,.xlsx

# AWS S3 (Optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
AWS_REGION=

# API
API_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000
MOBILE_APP_URL=

# Logging
LOG_LEVEL=debug